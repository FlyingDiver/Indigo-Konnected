<?xml version="1.0" encoding="UTF-8"?>
<Actions>
    <Action id="discoverDevices" deviceFilter="self">
        <Name>Discover Konnected Devices</Name>
        <CallbackMethod>discover_devices_action</CallbackMethod>
    </Action>
    
    <Action id="refreshPanelStatus" deviceFilter="self.konnectedPanel">
        <Name>Refresh Panel Status</Name>
        <CallbackMethod>refresh_panel_status_action</CallbackMethod>
    </Action>
    
    <Action id="testPanelConnection" deviceFilter="self.konnectedPanel">
        <Name>Test Panel Connection</Name>
        <CallbackMethod>test_panel_connection_action</CallbackMethod>
    </Action>
    
    <Action id="activateOutput" deviceFilter="self.konnectedOutput">
        <Name>Activate Output</Name>
        <CallbackMethod>activate_output_action</CallbackMethod>
        <ConfigUI>
            <Field id="duration" type="textfield" defaultValue="5">
                <Label>Duration (seconds, 0 for permanent):</Label>
            </Field>
        </ConfigUI>
    </Action>

    <!-- GDO Blaq Actions -->
    <Action id="openGarageDoor" deviceFilter="self.konnectedGDO">
        <Name>Open Garage Door</Name>
        <CallbackMethod>open_garage_door_action</CallbackMethod>
    </Action>
    
    <Action id="closeGarageDoor" deviceFilter="self.konnectedGDO">
        <Name>Close Garage Door</Name>
        <CallbackMethod>close_garage_door_action</CallbackMethod>
    </Action>
    
    <Action id="stopGarageDoor" deviceFilter="self.konnectedGDO">
        <Name>Stop Garage Door</Name>
        <CallbackMethod>stop_garage_door_action</CallbackMethod>
    </Action>
    
    <Action id="toggleGarageDoor" deviceFilter="self.konnectedGDO">
        <Name>Toggle Garage Door</Name>
        <CallbackMethod>toggle_garage_door_action</CallbackMethod>
    </Action>
    
    <Action id="setGarageDoorPosition" deviceFilter="self.konnectedGDO">
        <Name>Set Garage Door Position</Name>
        <CallbackMethod>set_garage_door_position_action</CallbackMethod>
        <ConfigUI>
            <Field id="position" type="textfield" defaultValue="50">
                <Label>Position (0-100%):</Label>
            </Field>
        </ConfigUI>
    </Action>
    
    <Action id="toggleGarageLight" deviceFilter="self.konnectedGDO">
        <Name>Toggle Garage Light</Name>
        <CallbackMethod>toggle_garage_light_action</CallbackMethod>
    </Action>
    
    <Action id="refreshGDOStatus" deviceFilter="self.konnectedGDO">
        <Name>Refresh GDO Status</Name>
        <CallbackMethod>refresh_gdo_status_action</CallbackMethod>
    </Action>

    <!-- GDO White Actions -->
    <Action id="openGarageDoorWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Open Garage Door</Name>
        <CallbackMethod>open_garage_door_white_action</CallbackMethod>
    </Action>
    
    <Action id="closeGarageDoorWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Close Garage Door</Name>
        <CallbackMethod>close_garage_door_white_action</CallbackMethod>
    </Action>
    
    <Action id="stopGarageDoorWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Stop Garage Door</Name>
        <CallbackMethod>stop_garage_door_white_action</CallbackMethod>
    </Action>
    
    <Action id="toggleGarageDoorWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Toggle Garage Door</Name>
        <CallbackMethod>toggle_garage_door_white_action</CallbackMethod>
    </Action>
    
    <Action id="setGarageDoorPositionWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Set Garage Door Position</Name>
        <CallbackMethod>set_garage_door_position_white_action</CallbackMethod>
        <ConfigUI>
            <Field id="position" type="textfield" defaultValue="50">
                <Label>Position (0-100%):</Label>
            </Field>
        </ConfigUI>
    </Action>
    
    <Action id="toggleGarageLightWhite" deviceFilter="self.konnectedGDOWhite">
        <Name>Toggle Garage Light</Name>
        <CallbackMethod>toggle_garage_light_white_action</CallbackMethod>
    </Action>
    
    <Action id="refreshGDOWhiteStatus" deviceFilter="self.konnectedGDOWhite">
        <Name>Refresh GDO White Status</Name>
        <CallbackMethod>refresh_gdo_white_status_action</CallbackMethod>
    </Action>
</Actions>