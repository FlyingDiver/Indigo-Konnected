<?xml version="1.0" encoding="UTF-8"?>
<Devices>
    <Device type="custom" id="konnectedPanel">
        <Name>Konnected Panel</Name>
        <ConfigUI>
            <Field id="ip_address" type="textfield" defaultValue="">
                <Label>IP Address:</Label>
            </Field>
            <Field id="port" type="textfield" defaultValue="80">
                <Label>Port:</Label>
            </Field>
            <Field id="auth_token" type="textfield" defaultValue="">
                <Label>Authentication Token (if required):</Label>
            </Field>
            <Field id="poll_frequency" type="menu" defaultValue="30">
                <Label>Polling Frequency (seconds):</Label>
                <List>
                    <Option value="5">5 seconds</Option>
                    <Option value="10">10 seconds</Option>
                    <Option value="30">30 seconds</Option>
                    <Option value="60">60 seconds</Option>
                    <Option value="300">5 minutes</Option>
                </List>
            </Field>
        </ConfigUI>
        <States>
            <State id="connection_status">
                <ValueType>String</ValueType>
                <TriggerLabel>Connection Status</TriggerLabel>
                <ControlPageLabel>Connection Status</ControlPageLabel>
            </State>
            <State id="zones_configured">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Zones Configured</TriggerLabel>
                <ControlPageLabel>Zones Configured</ControlPageLabel>
            </State>
        </States>
    </Device>
    
    <Device type="sensor" id="konnectedSensor">
        <Name>Konnected Sensor</Name>
        <ConfigUI>
            <Field id="panel_device" type="menu">
                <Label>Konnected Panel:</Label>
                <List class="self" filter="" method="get_panel_devices"/>
            </Field>
            <Field id="zone_number" type="textfield" defaultValue="1">
                <Label>Zone Number (1-6 or 1-12):</Label>
            </Field>
            <Field id="sensor_type" type="menu" defaultValue="contact">
                <Label>Sensor Type:</Label>
                <List>
                    <Option value="contact">Contact Sensor (door/window)</Option>
                    <Option value="motion">Motion Sensor</Option>
                    <Option value="smoke">Smoke Detector</Option>
                    <Option value="co">CO Detector</Option>
                    <Option value="leak">Water Leak Sensor</Option>
                    <Option value="generic">Generic Sensor</Option>
                </List>
            </Field>
            <Field id="invert_logic" type="checkbox" defaultValue="false">
                <Label>Invert Logic:</Label>
                <Description>Check if sensor logic is inverted (normally closed becomes normally open)</Description>
            </Field>
        </ConfigUI>
        <States>
            <State id="sensorValue">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Sensor State</TriggerLabel>
                <ControlPageLabel>Sensor State</ControlPageLabel>
            </State>
            <State id="onOffState">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>On/Off State</TriggerLabel>
                <ControlPageLabel>On/Off State</ControlPageLabel>
            </State>
        </States>
    </Device>
    
    <Device type="relay" id="konnectedOutput">
        <Name>Konnected Output</Name>
        <ConfigUI>
            <Field id="panel_device" type="menu">
                <Label>Konnected Panel:</Label>
                <List class="self" filter="" method="get_panel_devices"/>
            </Field>
            <Field id="zone_number" type="textfield" defaultValue="7">
                <Label>Zone Number (typically 7-12 for outputs):</Label>
            </Field>
            <Field id="output_type" type="menu" defaultValue="siren">
                <Label>Output Type:</Label>
                <List>
                    <Option value="siren">Siren/Alarm</Option>
                    <Option value="strobe">Strobe Light</Option>
                    <Option value="relay">Generic Relay</Option>
                </List>
            </Field>
        </ConfigUI>
        <States>
            <State id="onOffState">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>On/Off State</TriggerLabel>
                <ControlPageLabel>On/Off State</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>onOffState</UiDisplayStateId>
    </Device>

    <Device type="custom" id="konnectedGDO">
        <Name>Konnected GDO Blaq</Name>
        <ConfigUI>
            <Field id="ip_address" type="textfield" defaultValue="">
                <Label>IP Address:</Label>
            </Field>
            <Field id="port" type="textfield" defaultValue="80">
                <Label>Port:</Label>
            </Field>
            <Field id="auth_username" type="textfield" defaultValue="">
                <Label>Username (if authentication enabled):</Label>
            </Field>
            <Field id="auth_password" type="textfield" defaultValue="">
                <Label>Password (if authentication enabled):</Label>
            </Field>
            <Field id="use_eventsource" type="checkbox" defaultValue="true">
                <Label>Use EventSource (SSE) for real-time monitoring:</Label>
                <Description>Enable Server-Sent Events for real-time status updates (more efficient than polling)</Description>
            </Field>
            <Field id="poll_frequency" type="menu" defaultValue="10">
                <Label>Polling Frequency (seconds):</Label>
                <Description>Used as fallback when EventSource is disabled or unavailable</Description>
                <List>
                    <Option value="5">5 seconds</Option>
                    <Option value="10">10 seconds</Option>
                    <Option value="30">30 seconds</Option>
                    <Option value="60">60 seconds</Option>
                </List>
            </Field>
        </ConfigUI>
        <States>
            <State id="door_state">
                <ValueType>String</ValueType>
                <TriggerLabel>Door State</TriggerLabel>
                <ControlPageLabel>Door State</ControlPageLabel>
            </State>
            <State id="door_operation">
                <ValueType>String</ValueType>
                <TriggerLabel>Door Operation</TriggerLabel>
                <ControlPageLabel>Door Operation</ControlPageLabel>
            </State>
            <State id="door_position">
                <ValueType>Integer</ValueType>
                <TriggerLabel>Door Position</TriggerLabel>
                <ControlPageLabel>Door Position (%)</ControlPageLabel>
            </State>
            <State id="light_state">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Light State</TriggerLabel>
                <ControlPageLabel>Light State</ControlPageLabel>
            </State>
            <State id="lock_state">
                <ValueType>String</ValueType>
                <TriggerLabel>Lock State</TriggerLabel>
                <ControlPageLabel>Lock State</ControlPageLabel>
            </State>
            <State id="motion_detected">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Motion Detected</TriggerLabel>
                <ControlPageLabel>Motion Detected</ControlPageLabel>
            </State>
            <State id="obstruction_detected">
                <ValueType>Boolean</ValueType>
                <TriggerLabel>Obstruction Detected</TriggerLabel>
                <ControlPageLabel>Obstruction Detected</ControlPageLabel>
            </State>
            <State id="connection_status">
                <ValueType>String</ValueType>
                <TriggerLabel>Connection Status</TriggerLabel>
                <ControlPageLabel>Connection Status</ControlPageLabel>
            </State>
        </States>
        <UiDisplayStateId>door_state</UiDisplayStateId>
    </Device>
</Devices>